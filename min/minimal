#!/usr/bin/env bash
# minimal — launcher
# Usage: minimal [--init] [--session <id>] [--model <model>]

set -e

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
BACKEND_DIR="$SCRIPT_DIR/backend"
TUI_DIR="$SCRIPT_DIR/tui"

MINIMAL_HOME="${MINIMAL_HOME:-$HOME/.minimal}"
VENV_DIR="$MINIMAL_HOME/venv"
VENV_PYTHON="$VENV_DIR/bin/python"
BACKEND_PORT=4096
BACKEND_PID_FILE="/tmp/minimal-$USER-backend.pid"
BACKEND_LOG="/tmp/minimal-$USER-backend.log"
MINIMAL_SESSION_FILE="/tmp/minimal-$USER-session"
BACKEND_OWNED=false
BACKEND_PID=""
MINIMAL_SESSION_ID=""

die() { echo "minimal: $*" >&2; exit 1; }
check_dep() { command -v "$1" >/dev/null 2>&1 || die "$1 is required but not found"; }

source "$SCRIPT_DIR/lib/backend.sh"
source "$SCRIPT_DIR/lib/init.sh"
source "$SCRIPT_DIR/lib/exit.sh"

if [ "${1:-}" = "--init" ]; then
    cmd_init
    exit 0
fi

[ ! -x "$VENV_PYTHON" ] && die "not initialized. Run: minimal --init"
check_dep bun

start_backend || exit 1

trap cleanup EXIT INT TERM

export MINIMAL_SESSION_FILE
cd "$TUI_DIR"
bun run index.tsx "$@"
TUI_EXIT=$?

[ $TUI_EXIT -ne 0 ] && echo "minimal: TUI exited with code $TUI_EXIT" >&2
exit $TUI_EXIT
